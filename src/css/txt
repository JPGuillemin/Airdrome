// Nav / Links
a.active,
.nav .nav-link.router-link-active,
.nav .nav-link.router-link-exact-active,
.nav .nav-link:hover {
  color: var(--bs-primary);
}
.nav .nav-link,
.nav a {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.4rem;
}
.nav .nav-link {
  color: var(--theme-text);
  text-decoration: none;
  transition: color 0.15s ease;
}
.main-content a:not(.genre-link) {
  text-decoration: none;
  color: var(--theme-text);
  transition: color 0.15s ease;
}

@media(max-width: 768px) {
  a.active,
  .nav .nav-link.router-link-active,
  .nav .nav-link.router-link-exact-active,
  .nav .nav-link:hover {
    color: var(--theme-text);
  }
}

ul.nav-underlined {
  white-space: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  padding-left: 0;
  padding-right: 0;
  margin-bottom: 0;
  font-weight: normal;
  li {
    display: inline-block;
    float: none;
    a {
      display: block;
      padding: 0.5rem 1rem;
    }
    a:hover, a:focus {
      text-decoration: none;
      border-bottom: 2px solid rgba(#fff, .25);
    }
    a.active {
      border-bottom: 2px solid;
    }
    a.active:hover {
      color: var(--bs-primary);
    }
  }
}

ul.nav-underlined::-webkit-scrollbar {
  display: none;
}

ul.nav {
  white-space: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  padding-left: 0;
  padding-right: 0;
  margin-bottom: 0;
  font-weight: normal;
  li {
    display: inline-block;
    float: none;
    a {
      display: block;
      padding: 0.5rem 1rem;
    }
    a:hover, a:focus {
      text-decoration: none;
    }
    a.active:hover {
      color: var(--bs-primary);
    }
  }
}

ul.nav::-webkit-scrollbar {
  display: none;
}
.scroll {
  overflow-x: auto;
  scrollbar-color: rgba(0,0,0,0.3) transparent;
}

/* WebKit browsers (Chrome, Safari, Edge) */
.scroll::-webkit-scrollbar {
  height: 20px; /* horizontal scrollbar thickness */
}

.scroll::-webkit-scrollbar-button {
  display: none; /* remove arrows */
}

.scroll::-webkit-scrollbar-thumb {
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 10px;
}

.scroll::-webkit-scrollbar-track {
  background: transparent;
  border-radius: 10px;
}

/* Mobile: hide scrollbar */
@media (max-width: 768px) {
  .scroll {
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
  }
  .scroll::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }
}
/* Base table reset */
table,
th,
td {
  border: none;
}

/* Table header */
table thead tr {
  font-size: 80%;
  text-transform: uppercase;
  color: var(--bs-secondary-color);
}

/* Generic table */
table.table {
  th {
    color: var(--bs-secondary-color);
  }
  tr {
    cursor: pointer;
    background-color: var(--bs-body-bg, white);
  }
  tr.active {
    td,
    td a,
    td button.dropdown-toggle {
      color: var(--bs-primary);
    }
  }
  tr.disabled {
    cursor: default;
    td,
    td a,
    td button.dropdown-toggle {
      color: var(--bs-secondary-color);
    }
    button {
      cursor: default;
    }
  }
}

/* Numbered table specific styling */
table.table-numbered {
  th:first-child,
  td:first-child {
    padding-left: 0;
    padding-right: 0;
    width: 26px;
    max-width: 26px;
    text-align: center;
    color: var(--bs-secondary-color);
  }
  tr td:first-child button {
    border: none;
    background: none;
    color: inherit;
    font: inherit;
    outline: inherit;
    .number {
      display: inline;
      white-space: nowrap;
    }
    .icon {
      display: none;
    }
  }
  tr.active td:first-child button {
    .number {
      display: none;
    }
    .icon {
      display: inline;
    }
  }
  tr.disabled td:first-child button {
    .number {
      display: inline;
    }
    .icon {
      display: none;
    }
  }
  tbody tr:hover td .number {
    display: none;
  }
  tbody tr:hover td:first-child .icon {
    display: inline;
    color: var(--bs-primary);
  }
  tbody tr td {
    cursor: pointer;
  }
}

$table-cell-padding-y: 0.75rem;
$table-cell-padding-x: 0.75rem;
$theme-elevation-0: #000000;
$theme-elevation-1: #171717;
$theme-elevation-2: #303030;
$theme-elevation-3: #404040;
$theme-elevation-4: #707070;
$theme-text: #bfbfbf;
$theme-text-muted: #b0b0b0;
$blue: #178994;
$green: #1db954;
$orange: #ff8c00;
$purple: #6f42c1;
$red: #bf0000;

// Bootstrap overrides
$primary: $blue;
$danger: #ff4141;
$secondary: $theme-text-muted;

$body-bg: $theme-elevation-0;
$body-color: $theme-text;

$grid-gutter-width: 2rem;

$headings-color: #ffffff;

$link-color: $theme-text;
$link-decoration: none;
$link-hover-decoration: underline;

$text-muted: $theme-text-muted;
$border-color: $theme-elevation-2;

:root {
  --theme-text-muted: #{$theme-text-muted};
  --theme-text: #{$theme-text};
  --theme-elevation-0: #{$theme-elevation-0};
  --theme-elevation-1: #{$theme-elevation-1};
  --theme-elevation-2: #{$theme-elevation-2};
  --theme-elevation-3: #{$theme-elevation-3};
  --theme-elevation-4: #{$theme-elevation-4};
  --primary: #{$primary};
  --secondary: #{$secondary};
  --mobile-nav-height: 60px;
  user-select: none;
  -webkit-user-select: none;
  caret-color: transparent;
}

.theme-primary {
  background-color: transparent !important;
  border: none !important;
  color: var(--bs-primary) !important;
}

.theme-primary:hover,
.theme-primary:focus {
  color: color-mix(in srgb, var(--bs-primary) 90%, black 10%) !important;
}

.theme-primary:active {
  color: color-mix(in srgb, var(--bs-primary) 80%, black 20%) !important;
}

.btn-theme-primary {
  background-color: var(--bs-primary) !important;
  border-color: var(--bs-primary) !important;
  color: #fff !important;
}

.btn-theme-primary:hover,
.btn-theme-primary:focus {
  background-color: color-mix(in srgb, var(--bs-primary) 90%, black 10%) !important;
  border-color: color-mix(in srgb, var(--bs-primary) 90%, black 10%) !important;
  color: #fff !important;
}

.btn-theme-primary:active {
  background-color: color-mix(in srgb, var(--bs-primary) 80%, black 20%) !important;
  border-color: color-mix(in srgb, var(--bs-primary) 80%, black 20%) !important;
  color: #fff !important;
}

.btn-theme-primary:disabled {
  background-color: var(--bs-secondary) !important;
  border-color: var(--bs-secondary) !important;
  opacity: 0.65;
  color: #fff !important;
}

img {
