// =======================
// Buttons
// =======================

.btn-primary {
  --bs-btn-color: #ffffff !important;
  --bs-btn-hover-color: #ffffff !important;
  --bs-btn-active-color: #ffffff !important;
  --bs-btn-disabled-color: #ffffff !important;
}

// Transparent button
.btn-transparent {
  --bs-btn-color: var(--theme-text);
  --bs-btn-bg: transparent;
  --bs-btn-border-width: 0;

  --bs-btn-hover-color: var(--bs-primary);
  --bs-btn-hover-bg: transparent;

  --bs-btn-active-color: var(--bs-primary);
  --bs-btn-active-border-color: transparent;

  --bs-btn-focus-shadow-rgb: #{$theme-elevation-4};

  --bs-btn-disabled-color: var(--theme-text);
  --bs-btn-disabled-bg: transparent;
  --bs-btn-disabled-border-color: transparent;
}

// Link-style button
.btn-link:focus {
  box-shadow: none !important;
}

// =======================
// Base button behavior (FIXED)
// IMPORTANT: do NOT override disabled buttons
// =======================

.btn:not(:disabled):not(.disabled):hover,
.btn:not(:disabled):not(.disabled):active {
  color: var(--bs-btn-hover-color, var(--bs-primary));
}

@media (max-width: 768px) {
  .btn:not(:disabled):not(.disabled):hover,
  .btn:not(:disabled):not(.disabled):active {
    color: var(--theme-text);
  }
}

// =======================
// Close button
// =======================

$btn-close-color: var(--theme-text);
// Inputs

html, body, * {
  user-select: none;
  -webkit-user-select: none;
}

input, textarea {
  user-select: text;
  -webkit-user-select: text;
  caret-color: var(--theme-text);
}

// Dropdown
$dropdown-bg: $theme-elevation-1;
$dropdown-link-color: $theme-text;
$dropdown-link-hover-bg: $theme-elevation-2;
$dropdown-link-hover-color: var(--bs-primary);
$dropdown-border-color: $theme-elevation-2;
$dropdown-divider-bg: $theme-elevation-2;
.dropdown-toggle.dropdown-toggle-no-caret::before,
.dropdown-toggle.dropdown-toggle-no-caret::after {
  display: none !important;
}

// Tooltip
$tooltip-bg: $theme-elevation-1;
$tooltip-color: $theme-text;
.tooltip {
  position: absolute;
  z-index: 3000 !important;
}

// Forms
$input-bg: $theme-elevation-2;
$input-disabled-bg: $theme-elevation-1;
$input-border-color: $theme-elevation-2;
$input-color: $theme-text;
$custom-range-track-height: 0.1rem;
$custom-range-thumb-bg: $theme-text;
$custom-range-track-bg: $theme-text;

// List group
$list-group-bg: rgba(#ffffff, 0);
$list-group-hover-bg: #ffffff1a;
$list-group-color: $theme-text;
$list-group-action-hover-color: $theme-text;
$list-group-border-color: $theme-elevation-2;
$list-group-action-active-bg: #ffffff1a;

// Offcanvas
$offcanvas-bg-color: $theme-elevation-1;

// Card
$card-bg: $theme-elevation-1;
$card-cap-bg: $theme-elevation-1;
$card-spacer-y: 1.25rem;
$card-spacer-x: 1.25rem;

// Modal
$modal-content-bg: $theme-elevation-1;
$modal-content-border-color: $theme-elevation-2;
.modal-backdrop {
  opacity: 0.5;
}

// Popover
$popover-bg: $theme-elevation-1;
$popover-border-color: $theme-elevation-2;

// Misc
.selectable,
p,
span,
article,
.markdown {
  user-select: text;
  -webkit-user-select: text;
}
.main-content {
  padding-top: 38px;
  z-index: auto;
}

.main-content a {
  text-decoration: none;
  color: inherit;
  transition: color 0.15s ease;
}

.main-content a:hover {
  color: var(--bs-primary);
  text-decoration: none;
}

.main-content a.router-link-active,
.main-content a.router-link-exact-active {
  color: var(--bs-primary);
}

.main-title {
  display: inline-block;
  margin-block-start: 0.67em;
  margin-block-end: 0.67em;
  font-size: 1.5rem;
  line-height: 1.5;
  color: var(--theme-text);
  font-weight: 700;
  user-select: none;
  -webkit-user-select: none;
}

.section-title {
  display: inline-block;
  margin-block-start: 0.67em;
  margin-block-end: 0.67em;
  font-size: 1.2rem;
  line-height: 1.2;
  color: var(--theme-text);
  font-weight: 700;
  user-select: none;
  -webkit-user-select: none;
}

.content-wrapper {
  max-width: 100%;
  position: relative;
  z-index: auto;
  margin-top: 170px;
  padding: 1rem;
}

.section-wrapper {
  max-width: 100%;
  position: relative;
  z-index: auto;
  padding-bottom: 1.2rem;
}

.header-wrapper {
  position: fixed;
  width: 100%;
  z-index: 500;
  background: var(--bs-body-bg);
  overflow: visible;
}

.header-title-wrapper {
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.header-title {
  overflow: hidden;
  display: inline-block;
  max-width: calc(100% - 160px - 1rem);
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-block-start: 0.67em;
  margin-block-end: 0.67em;
  font-size: 1.5rem;
  line-height: 1.5;
  min-width: 0;
  flex-shrink: 1;
  color: var(--theme-text);
  font-weight: 700;
}

.header-title--secondary {
  margin-top: 7px;
  color: var(--theme-text);
  font-size: 1.2rem;
  font-weight: 700;
}

.header-info-wrapper {
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.header-info-one {
  overflow: hidden;
  display: inline-block;
  max-width: calc(100% - 160px - 1rem);
  flex-wrap: nowrap;
  white-space: nowrap;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;
  font-size: 1rem;
}

.header-info-two {
  overflow: hidden;
  display: inline-block;
  max-width: calc(100% - 160px - 1rem);
  flex-wrap: nowrap;
  white-space: nowrap;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;
  font-size: 0.9rem;
}

/* Text turns primary when its tile container is hovered */
.tile:hover .hover-tile-primary {
  color: var(--bs-primary);
  transition: color 0.2s ease-in-out;
}

/* Hover */
.main-content a:not(.genre-link):hover {
  color: var(--bs-primary);  /* highlight like button */
  text-decoration: none;      /* ensure no underline */
}

/* Active route */
.main-content a.router-link-active:not(.genre-link),
.main-content a.router-link-exact-active:not(.genre-link) {
  color: var(--bs-primary);
  text-decoration: none;
}

.main-content a.d-inline-flex:not(.genre-link) {
  align-items: center;
  text-decoration: none;
}

/* Section header links outside header, excluding genre-link */
.section-wrapper > div > a.d-inline-flex:not(.genre-link) {
  text-decoration: none;
  color: inherit; /* base color */
  transition: color 0.15s ease;
  align-items: center;
  display: inline-flex;
}

/* Hover state: change color for all children */
.section-wrapper > div > a.d-inline-flex:not(.genre-link):hover,
.section-wrapper > div > a.d-inline-flex:not(.genre-link).router-link-active,
.section-wrapper > div > a.d-inline-flex:not(.genre-link).router-link-exact-active {
  color: var(--bs-primary);
  text-decoration: none;
}

/* Make sure all children inherit hover color */
.section-wrapper > div > a.d-inline-flex:not(.genre-link):hover *,
.section-wrapper > div > a.d-inline-flex:not(.genre-link).router-link-active *,
.section-wrapper > div > a.d-inline-flex:not(.genre-link).router-link-exact-active * {
  color: inherit;
}

/* Mobile: slightly smaller font */
@media (max-width: 767px) {
  .main-title {
    max-width: 220px;
    font-size: 1.2rem !important;
  }
  .header-title {
    max-width: 220px;
    font-size: 1.2rem !important;
  }
  .section-title {
    max-width: 220px;
    font-size: 1.1rem !important;
  }
  .header-info-one {
    display: block;
    max-width: 220px;
    font-size: 0.9rem !important;
  }
  .header-info-two {
    display: block;
    max-width: 220px;
    font-size: 0.8rem !important;
  }
}

